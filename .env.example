# Copy to `.env.local` and fill in.

# --- IronRAG ---
IRONRAG_BASE_URL=http://localhost:19000
IRONRAG_API_TOKEN=changeme
ADMIN_BEARER_TOKEN=changeme

# --- Routing + repos ---
ROUTING_CONFIG_PATH=./routing.yaml
GITREPOS_CONFIG_PATH=./repos.yaml
GITREPOS_CLONE_ROOT=./repo-cache

# --- Sync loop ---
RUN_MODE=poll
SYNC_INTERVAL_SECONDS=1800
SYNC_RUN_ON_STARTUP=true
SYNC_CONCURRENCY=4

# --- Limits ---
GITREPOS_FETCH_TIMEOUT_SECONDS=180
GITREPOS_COMMAND_TIMEOUT_SECONDS=60
GITREPOS_MAX_FILE_BYTES=1048576

# --- Server / persistence ---
HOST=0.0.0.0
PORT=8088
LOG_LEVEL=info
STATE_DB_PATH=./connector-state.sqlite

# --- Default per-kind policy (overridable in routing.yaml) ---
DEFAULT_POLICY_ON_NEW=create
DEFAULT_POLICY_ON_CHANGED=replace
DEFAULT_POLICY_ON_MISSING=delete
DEFAULT_POLICY_ON_DUPLICATE_CONTENT=skip
